LISTEN_PORT=6343
FORWARD_IP=192.168.1.10
FORWARD_PORT=6343
FORWARD_RATE=100
DEFAULT_SAMPLING_RATE=512

# Optional: per-device sampling rate overrides.
# Comma-separated ip:rate pairs. The device's agent_address (from the sFlow
# header) is matched against this list. Takes precedence over both the
# embedded rate and DEFAULT_SAMPLING_RATE.
# DEVICE_RATES=192.168.1.1:1000,10.0.0.5:512

# How long a source must be silent before it is logged again (seconds).
# Default: 300 (5 minutes). Set to 0 to log every packet (verbose).
# SOURCE_LOG_INTERVAL=300

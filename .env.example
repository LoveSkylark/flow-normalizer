# Downstream collector — shared by both sFlow and NetFlow.
FORWARD_IP=192.168.1.10
FORWARD_RATE=100

# ── sFlow ─────────────────────────────────────────────────────────────────────
# In Docker, SFLOW_PORT only controls the external host port — the container
# always binds internally on 6343.
SFLOW_PORT=6343
SFLOW_FORWARD_PORT=6343

# ── NetFlow / IPFIX ───────────────────────────────────────────────────────────
# Accepts v5, v9, and IPFIX. v5 is converted to v9 on output.
# In Docker, NETFLOW_LISTEN_PORT only controls the external host port — the
# container always binds internally on 2055.
NETFLOW_LISTEN_PORT=2055
NETFLOW_FORWARD_PORT=2055

# ── Sampling rate ─────────────────────────────────────────────────────────────
# Assumed input rate for devices that send no embedded sampling rate.
# Applies to both sFlow (sampling_rate=0) and NetFlow (no Options Template).
DEFAULT_SAMPLING_RATE=512

# Per-device overrides. Comma-separated ip:rate pairs. Matched against
# sFlow agent_address or NetFlow UDP source IP. Takes precedence over both
# the embedded rate and DEFAULT_SAMPLING_RATE.
# DEVICE_RATES=192.168.1.1:1000,10.0.0.5:512

# ── Source IP spoofing (UDP only) ─────────────────────────────────────────────
# When enabled, forwarded UDP packets use the original device's source IP so
# the downstream collector sees the real exporter rather than this host.
# UDP only — TCP transparent proxying is not supported.
# Requires CAP_NET_ADMIN; added to docker-compose.yml
# SPOOF_UDP_SOURCE=false

# ── Logging ───────────────────────────────────────────────────────────────────
# How long a source must be silent before it is logged again (seconds).
# Default: 300 (5 minutes). Set to 0 to log every packet (verbose).
# SOURCE_LOG_INTERVAL=300
